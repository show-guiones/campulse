{
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "headers": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "campulse-sooty.vercel.app"
        }
      ],
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        }
      ]
    },
    {
      "source": "/model/lexy_fox2",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "s-maxage=60, stale-while-revalidate=300"
        },
        {
          "key": "X-Robots-Tag",
          "value": "index,follow"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/rss.xml",
      "destination": "/api/rss"
    }
  ]
}